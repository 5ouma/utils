{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>5ouma/utils"],
  "pre-commit": { "enabled": true },
  "renovate-config-presets": {
    "managerFilePatterns": ["/(^|/).?(renovate(?:rc)?|default)(?:\\.json5?)?$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["pre-commit/action.yml"],
      "matchStrings": [
        "PREK_VERSION: (?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "j178/prek"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [".pre-commit-config.yaml"],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver",
      "matchStrings": [
        "github\\.com/(?<depName>[^/]+/[^\\s/]+)(?:/[^@]+)?@(?<currentDigest>[0-9a-f]{40}) # frozen: (?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ]
    }
  ]
}
